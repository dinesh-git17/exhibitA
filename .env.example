# Exhibit A Backend Configuration
# Copy to .env and fill in values before deployment.

# Database
DATABASE_PATH=data/exhibit-a.db

# Server
HOST=127.0.0.1
PORT=8001
DEBUG=false

# APNS (Apple Push Notification Service)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=

# Admin Authentication
ADMIN_KEY_HASH=
