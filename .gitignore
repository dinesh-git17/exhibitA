*.xcactivitylog

# Swift Package Manager
.swiftpm/
.build/
Package.resolved
Packages/

# SwiftLint / SwiftFormat caches
.swiftlint/

# ─────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
*.so
*.pyd

# Virtual environment
.venv/

# Type checking / linting caches
.mypy_cache/
.ruff_cache/
.pytest_cache/

# ─────────────────────────────────────────────────
# Secrets & Environment
# ─────────────────────────────────────────────────
.env
.env.*
!.env.example
*.p8
*.p12
*.pem
*.key

# Xcconfig with secrets (per-signer build variants)
*.xcconfig
!*.xcconfig.example

# ─────────────────────────────────────────────────
