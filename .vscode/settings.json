{
  // ─────────────────────────────────────────────────
  // Editor Defaults
  // ─────────────────────────────────────────────────
  "files.encoding": "utf8",
  "files.eol": "\n",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.renderWhitespace": "boundary",
  "editor.rulers": [
    88,
    120
  ],
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.minimap.enabled": true,
  "editor.stickyScroll.enabled": true,
  // ─────────────────────────────────────────────────
  // File Associations
  // ─────────────────────────────────────────────────
  "files.associations": {
    "*.html": "jinja-html",
    "litestream.yml": "yaml",
    "start.sh": "shellscript",
    ".swiftlint.yml": "yaml",
    ".swiftformat": "properties",
    "CODEOWNERS": "plaintext"
  },
  // ─────────────────────────────────────────────────
  // File Exclusions
  // ─────────────────────────────────────────────────
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/DerivedData": true,
    "**/xcuserdata": true,
    "**/.swiftpm": true,
    "**/.build": true,
    "**/__pycache__": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/.pytest_cache": true,
    "**/*.pyc": true
  },
  "search.exclude": {
    "**/DerivedData": true,
    "**/.venv": true,
    "**/__pycache__": true,
    "**/.mypy_cache": true,
    "**/data/*.db": true,
    "**/data/*.db-wal": true,
    "**/data/*.db-shm": true
  },
  // ─────────────────────────────────────────────────
  // Python (FastAPI Backend) -- ruff format, line 88
  // ─────────────────────────────────────────────────
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.rulers": [
      88
    ],
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },
  "python.analysis.typeCheckingMode": "strict",
  "python.analysis.autoImportCompletions": true,
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  // ─────────────────────────────────────────────────
  // Swift (iOS App) -- SwiftFormat + SwiftLint
  // ─────────────────────────────────────────────────
  "[swift]": {
    "editor.defaultFormatter": "vknabel.vscode-swiftformat",
    "editor.formatOnSave": true,
    "editor.tabSize": 4,
    "editor.rulers": [
      120
    ]
  },
  // ─────────────────────────────────────────────────
  // HTML / Jinja2 (Admin Panel Templates)
  // ─────────────────────────────────────────────────
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features",
    "editor.formatOnSave": false,
    "editor.tabSize": 2
  },
  "[jinja-html]": {
    "editor.formatOnSave": false,
    "editor.tabSize": 2
  },
  // ─────────────────────────────────────────────────
  // CSS (Admin Panel Styles)
  // ─────────────────────────────────────────────────
  "[css]": {
    "editor.defaultFormatter": "vscode.css-language-features",
    "editor.tabSize": 2
  },
  // ─────────────────────────────────────────────────
  // JSON / YAML / TOML
  // ─────────────────────────────────────────────────
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.tabSize": 2
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.tabSize": 2
  },
  "[yaml]": {
    "editor.tabSize": 2
  },
  "[toml]": {
    "editor.tabSize": 2
  },
  "evenBetterToml.schema.enabled": false,
  // ─────────────────────────────────────────────────
  // Shell Scripts
  // ─────────────────────────────────────────────────
  "[shellscript]": {
    "editor.tabSize": 4
  },
  // ─────────────────────────────────────────────────
  // SQL
  // ─────────────────────────────────────────────────
  "[sql]": {
    "editor.tabSize": 4
  },
  // ─────────────────────────────────────────────────
  // Markdown -- Professional Documentation Linting
  // ─────────────────────────────────────────────────
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
    "editor.formatOnSave": false,
    "editor.codeActionsOnSave": {
      "source.fixAll.markdownlint": "explicit"
    },
    "editor.wordWrap": "bounded",
    "editor.wordWrapColumn": 120,
    "editor.rulers": [
      120
    ],
    "editor.quickSuggestions": {
      "other": false,
      "comments": false,
      "strings": false
    },
    "files.trimTrailingWhitespace": false
  },
  "rewrap.wrappingColumn": 120,
  "rewrap.wholeComment": true,
  "markdownlint.config": {
    "default": true,
    // MD001: Heading levels increment by one
    "MD001": true,
    // MD003: Heading style -- ATX only (# prefix)
    "MD003": {
      "style": "atx"
    },
    // MD004: Unordered list style -- consistent dashes
    "MD004": {
      "style": "dash"
    },
    // MD007: Unordered list indentation -- 2 spaces
    "MD007": {
      "indent": 2
    },
    // MD009: No trailing spaces (except two-space line break)
    "MD009": {
      "br_spaces": 2
    },
    // MD010: No hard tabs
    "MD010": true,
    // MD012: No multiple consecutive blank lines
    "MD012": {
      "maximum": 1
    },
    // MD013: Line length -- 120 for readability, tables exempt
    "MD013": {
      "line_length": 120,
      "heading_line_length": 120,
      "code_block_line_length": 120,
      "tables": false,
      "stern": false
    },
    // MD014: Dollar signs in commands without output
    "MD014": true,
    // MD018: Space after hash in ATX heading
    "MD018": true,
    // MD060: No bare URLs in links (allow in text for readability)
    "MD060": false,
    // MD019: No multiple spaces after hash
    "MD019": true,
    // MD022: Headings surrounded by blank lines
    "MD022": {
      "lines_above": 1,
      "lines_below": 1
    },
    // MD023: Headings not indented
    "MD023": true,
    // MD024: No duplicate headings (siblings only)
    "MD024": {
      "siblings_only": true
    },
    // MD025: Single top-level heading per document -- disabled
    "MD025": false,
    // MD026: No trailing punctuation in headings
    "MD026": {
      "punctuation": ".,;:!"
    },
    // MD027: No multiple spaces after blockquote
    "MD027": true,
    // MD028: No blank line inside blockquote
    "MD028": true,
    // MD029: Ordered list item prefix -- sequential
    "MD029": {
      "style": "ordered"
    },
    // MD030: Spaces after list markers
    "MD030": true,
    // MD031: Fenced code blocks surrounded by blank lines
    "MD031": true,
    // MD032: Lists surrounded by blank lines
    "MD032": true,
    // MD033: No inline HTML (allow details/summary for collapsibles)
    "MD033": {
      "allowed_elements": [
        "details",
        "summary",
        "br",
        "sub",
        "sup"
      ]
    },
    // MD034: No bare URLs
    "MD034": true,
    // MD035: Horizontal rule style -- three dashes
    "MD035": {
      "style": "---"
    },
    // MD036: No emphasis as heading substitute
    "MD036": false,
    // MD037: No spaces inside emphasis markers
    "MD037": true,
    // MD038: No spaces inside code spans
    "MD038": true,
    // MD039: No spaces inside link text
    "MD039": true,
    // MD040: Fenced code blocks must have language specified -- disabled
    "MD040": false,
    // MD041: First line should be top-level heading
    "MD041": true,
    // MD042: No empty links
    "MD042": true,
    // MD044: Proper names capitalization -- disabled (project-specific terms vary)
    "MD044": false,
    // MD045: Images should have alt text
    "MD045": true,
    // MD046: Code block style -- fenced only
    "MD046": {
      "style": "fenced"
    },
    // MD047: Files end with single newline
    "MD047": true,
    // MD048: Code fence style -- backtick only
    "MD048": {
      "style": "backtick"
    },
    // MD049: Emphasis style -- asterisks
    "MD049": {
      "style": "asterisk"
    },
    // MD050: Strong emphasis style -- double asterisks
    "MD050": {
      "style": "asterisk"
    },
    // MD051: Link fragments should be valid
    "MD051": true,
    // MD052: Reference links and images should use defined label
    "MD052": true,
    // MD053: Link and image reference definitions should be needed
    "MD053": true
  },
  // ─────────────────────────────────────────────────
  // Git
  // ─────────────────────────────────────────────────
  "git.autofetch": false,
  "git.confirmSync": true,
  "git.enableSmartCommit": false,
  "git.inputValidationSubjectLength": 72,
  "git.branchProtection": [
    "main"
  ],
  // ─────────────────────────────────────────────────
  // Terminal
  // ─────────────────────────────────────────────────
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.scrollback": 10000,
  // ─────────────────────────────────────────────────
  // Telemetry
  // ─────────────────────────────────────────────────
  "telemetry.telemetryLevel": "off",
  "python-envs.defaultEnvManager": "ms-python.python:venv"
}
